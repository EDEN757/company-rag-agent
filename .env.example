# Copy to `.env` and edit. Source it before running the agent or indexer:
#   set -a; source .env; set +a
#
# The same code runs locally and on Nuvolos — only this file differs.
# Comments below show both target environments.

# --- Retrieval index ---------------------------------------------------------
# Path to the pre-built SQLite index (~344 MB, 35k chunks).
# Local (Edo's mac, shared with the older TEST workspace):
RAG_DB_PATH=/Users/edoardoschiatti/Documents/GitHub/TEST/RAG_PI/01-personal/data/index/rag.db
# Nuvolos Backend app — put the index on shared LFS so all instances see it:
# RAG_DB_PATH=/space_mounts/pars/rag_index/rag.db

# --- Ollama endpoint ---------------------------------------------------------
# Both local and Nuvolos Backend run Ollama on localhost:11434 by default.
# Override only if the Frontend app needs to reach a different Backend host.
OLLAMA_HOST=http://127.0.0.1:11434

# --- Embedding model ---------------------------------------------------------
# Used by both the Python indexer (indexing/embed.py) and the TS query path
# (src/rag/embed.ts). Must match what the index was built with (768-dim).
RAG_EMBED_MODEL=nomic-embed-text

# --- Chat model --------------------------------------------------------------
# Local dev: custom 32k-context build of qwen3.5:9b created via Modelfile.
LLM_MODEL=qwen3.5-9b-32k
# Nuvolos: course requires <=8B open model. qwen3:8b emits a <think> block by
# default, so always pass think=false in the request (see src/model.ts).
# LLM_MODEL=qwen3:8b

# Set to "1" only when LLM_MODEL is a qwen3-family model that emits <think>.
# qwen3.5:9b doesn't need this; qwen3:8b does.
LLM_DISABLE_THINKING=0

# --- Web server (frontend) ---------------------------------------------------
# Port the Node server (npm run server) listens on. Defaults to 3000 if unset.
# PORT=3000
